#!/bin/bash
# update-tokens
# Script to update tokens in opencode_env.sh
# Usage: update-tokens [options]
#
# QUICK START:
#   update-tokens --status        # Check current token status
#   update-tokens --help          # Show full help
#
# EXAMPLES:
#   update-tokens --github-token "ghp_xxx"
#   update-tokens --github-token "ghp_xxx" --aws-token "aws_xxx" --dry-run

set -e

ENV_FILE="${HOME}/opencode_workspace/opencode_env.sh"

# Remote servers (must be mounted via rclone)
REMOTE_SERVERS=("b70" "b60")
REMOTE_ENV_PATH="home/johnypau/opencode_workspace/opencode_env.sh"

DRY_RUN=0

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

usage() {
    cat << 'EOF'
Usage: update-tokens [OPTIONS]

Update tokens in opencode_env.sh environment file.

OPTIONS:
    -f, --file PATH      Path to opencode_env.sh (default: ~/opencode_workspace/opencode_env.sh)
    -d, --dry-run        Show what would be changed without making changes
    -h, --help           Show this help message
    --status             Show current token status (set/not set)

TOKENS:
    --aws-token TOKEN         Update AWS_BEARER_TOKEN_BEDROCK
    --jira-token TOKEN        Update JIRA_PAT
    --hf-token TOKEN          Update HF_TOKEN
    --github-token TOKEN      Update GITHUB_TOKEN
    --wiki-token TOKEN        Update WIKI_TOKEN
    --anthropic-token TOKEN   Update ANTHROPIC_AUTH_TOKEN

EXAMPLES:
    # Check current token status
    update-tokens --status

    # Update single token
    update-tokens --github-token "ghp_xxxxxxxxxxxx"

    # Update multiple tokens
    update-tokens --github-token "ghp_xxx" --aws-token "aws_xxx"

    # Dry run to preview changes
    update-tokens --github-token "ghp_xxx" --dry-run

    # Use custom env file path
    update-tokens -f /path/to/opencode_env.sh --github-token "ghp_xxx"

QUICK REFERENCE:
    update-tokens --status                    # See all token status
    update-tokens --github-token "ghp_xxx"    # Update GitHub token
    update-tokens --aws-token "xxx" --dry-run # Preview AWS token update

EOF
}

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

update_token() {
    local var_name="$1"
    local new_value="$2"
    local file="$3"

    if [ ! -f "$file" ]; then
        log_error "File not found: $file"
        return 1
    fi

    # Check if variable exists in file
    if ! grep -q "^export ${var_name}=" "$file"; then
        log_warn "Variable ${var_name} not found in ${file}"
        return 1
    fi

    # Get current value (for display)
    local current_value
    current_value=$(grep "^export ${var_name}=" "$file" | cut -d'=' -f2- | sed 's/^"//;s/"$//')

    # Mask values for display
    local masked_current="<not set>"
    local masked_new="<not set>"

    if [ -n "$current_value" ] && [ "$current_value" != "<your-${var_name,,}-here>" ] && [ "$current_value" != "<your-$(echo "$var_name" | tr '[:upper:]' '[:lower:]' | tr '_' '-')-here>" ]; then
        masked_current="${current_value:0:4}****${current_value: -4}"
    fi

    if [ -n "$new_value" ]; then
        masked_new="${new_value:0:4}****${new_value: -4}"
    fi

    if [ "$DRY_RUN" -eq 1 ]; then
        echo "  [DRY-RUN] Would update: ${var_name}"
        echo "            Current: ${masked_current}"
        echo "            New:     ${masked_new}"
        return 0
    fi

    # Escape special characters in the value for sed
    local escaped_value
    escaped_value=$(printf '%s\n' "$new_value" | sed -e 's/[\\/&]/\\&/g' -e 's/"//g')

    # Update the file
    if sed -i "s|^export ${var_name}=.*|export ${var_name}=\"${escaped_value}\"|" "$file"; then
        log_info "Updated ${var_name}: ${masked_current} -> ${masked_new}"
        return 0
    else
        log_error "Failed to update ${var_name}"
        return 1
    fi
}

show_current_tokens() {
    local file="$1"

    if [ ! -f "$file" ]; then
        log_error "File not found: $file"
        return 1
    fi

    echo ""
    echo "Current token status in: ${file}"
    echo "========================================"

    local vars=("AWS_BEARER_TOKEN_BEDROCK" "JIRA_PAT" "HF_TOKEN" "GITHUB_TOKEN" "WIKI_TOKEN" "ANTHROPIC_AUTH_TOKEN")

    for var in "${vars[@]}"; do
        local value
        value=$(grep "^export ${var}=" "$file" 2>/dev/null | cut -d'=' -f2- | sed 's/^"//;s/"$//' || echo "<not found>")

        local status="❌"
        local masked="<not set>"

        if [ -n "$value" ] && [ "$value" != "<your-aws-bearer-token-here>" ] && [ "$value" != "<your-jira-pat-here>" ] && [ "$value" != "<your-huggingface-token-here>" ] && [ "$value" != "<your-github-token-here>" ] && [ "$value" != "<your-wiki-token-here>" ] && [ "$value" != "<your-anthropic-auth-token-here>" ]; then
            status="✅"
            masked="${value:0:4}****${value: -4}"
        fi

        printf "  %s %-25s %s\n" "$status" "$var:" "$masked"
    done
    echo ""
}

# Parse arguments
AWS_TOKEN=""
JIRA_TOKEN=""
HF_TOKEN=""
GITHUB_TOKEN_VAL=""
WIKI_TOKEN=""
ANTHROPIC_TOKEN=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--file)
            ENV_FILE="$2"
            shift 2
            ;;
        -d|--dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --aws-token)
            AWS_TOKEN="$2"
            shift 2
            ;;
        --jira-token)
            JIRA_TOKEN="$2"
            shift 2
            ;;
        --hf-token)
            HF_TOKEN="$2"
            shift 2
            ;;
        --github-token)
            GITHUB_TOKEN_VAL="$2"
            shift 2
            ;;
        --wiki-token)
            WIKI_TOKEN="$2"
            shift 2
            ;;
        --anthropic-token)
            ANTHROPIC_TOKEN="$2"
            shift 2
            ;;
        --status)
            show_current_tokens "$ENV_FILE"
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            usage
            exit 1
            ;;
    esac
done

# Main execution
main() {
    # Resolve home directory in path
    ENV_FILE="${ENV_FILE/#\~/$HOME}"

    # Check if env file exists
    if [ ! -f "$ENV_FILE" ]; then
        log_error "Environment file not found: ${ENV_FILE}"
        log_info "Use -f flag to specify a different path"
        exit 1
    fi

    # Check if any tokens provided
    if [ -z "$AWS_TOKEN" ] && [ -z "$JIRA_TOKEN" ] && [ -z "$HF_TOKEN" ] && [ -z "$GITHUB_TOKEN_VAL" ] && [ -z "$WIKI_TOKEN" ] && [ -z "$ANTHROPIC_TOKEN" ]; then
        show_current_tokens "$ENV_FILE"
        echo "No tokens provided to update."
        echo "Use --help for usage information."
        exit 0
    fi

    log_info "Updating tokens in: ${ENV_FILE}"

    if [ "$DRY_RUN" -eq 1 ]; then
        log_warn "DRY RUN mode - no changes will be made"
    fi

    local errors=0

    # Update tokens
    if [ -n "$AWS_TOKEN" ]; then
        update_token "AWS_BEARER_TOKEN_BEDROCK" "$AWS_TOKEN" "$ENV_FILE" || ((errors++))
    fi

    if [ -n "$JIRA_TOKEN" ]; then
        update_token "JIRA_PAT" "$JIRA_TOKEN" "$ENV_FILE" || ((errors++))
    fi

    if [ -n "$HF_TOKEN" ]; then
        update_token "HF_TOKEN" "$HF_TOKEN" "$ENV_FILE" || ((errors++))
    fi

    if [ -n "$GITHUB_TOKEN_VAL" ]; then
        update_token "GITHUB_TOKEN" "$GITHUB_TOKEN_VAL" "$ENV_FILE" || ((errors++))
    fi

    if [ -n "$WIKI_TOKEN" ]; then
        update_token "WIKI_TOKEN" "$WIKI_TOKEN" "$ENV_FILE" || ((errors++))
    fi

    if [ -n "$ANTHROPIC_TOKEN" ]; then
        update_token "ANTHROPIC_AUTH_TOKEN" "$ANTHROPIC_TOKEN" "$ENV_FILE" || ((errors++))
    fi

    if [ "$errors" -gt 0 ]; then
        log_error "Completed with ${errors} error(s)"
        exit 1
    fi

    if [ "$DRY_RUN" -eq 0 ]; then
        log_info "Token update completed successfully!"
        log_info "Source the file to apply changes: source ${ENV_FILE}"

        # Copy updated file to remote servers if mounted
        log_info "Syncing to remote servers..."
        for server in "${REMOTE_SERVERS[@]}"; do
            local remote_dir="${HOME}/remote/${server}/$(dirname ${REMOTE_ENV_PATH})"
            local remote_file="${HOME}/remote/${server}/${REMOTE_ENV_PATH}"

            if [ -d "$remote_dir" ]; then
                if cp "$ENV_FILE" "$remote_file"; then
                    log_info "✓ Copied to ${server}:${remote_file}"
                else
                    log_error "✗ Failed to copy to ${server}"
                fi
            else
                log_warn "⚠ ${server} not mounted (run: rclone-init)"
            fi
        done
    else
        log_info "Dry run completed"
        log_info "Would copy to remote servers if mounted: ${REMOTE_SERVERS[*]}"
    fi
}

main "$@"

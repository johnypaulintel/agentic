#!/bin/bash
# opencode-init - Initialize workspace with tools and diary skill

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

DEST_DIR="$(pwd)"
TEMP_DIR="$DEST_DIR/.tmp_opencode_init"
ERRORS=0

# Helper functions
info() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; ERRORS=$((ERRORS + 1)); }
step() { echo -e "\n${GREEN}▶${NC} $1"; }

# Cleanup on exit
cleanup() {
    rm -rf "$TEMP_DIR" 2>/dev/null || true
}
trap cleanup EXIT

# Check if current directory is not empty
if [ "$(ls -A "$DEST_DIR" 2>/dev/null | wc -l)" -gt 0 ]; then
    warn "Current directory is not empty!"
    echo "  Files will be copied to: $DEST_DIR"
    read -p "  Continue? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        info "Aborted."
        exit 0
    fi
fi

step "Initializing opencode workspace..."

# Setup repo URL
if [ -n "$GITHUB_TOKEN" ]; then
    REPO_URL="https://${GITHUB_TOKEN}@github.com/johnypaulintel/claude.automation.aep-tools.ae-partner.git"
else
    REPO_URL="https://github.com/johnypaulintel/claude.automation.aep-tools.ae-partner.git"
fi
SOURCE_PATH="src/scripts/cri_sdv_tests"

mkdir -p "$TEMP_DIR"

# Clone main repo
step "Downloading tools..."
if ! git clone --depth 1 "$REPO_URL" "$TEMP_DIR/repo" >/dev/null 2>&1; then
    error "Failed to clone tools repository"
    exit 1
fi

# Copy files (including hidden directories)
shopt -s dotglob
if ! cp -r "$TEMP_DIR/repo/$SOURCE_PATH/"* "$DEST_DIR/" 2>/dev/null; then
    error "Failed to copy tool files"
    exit 1
fi
shopt -u dotglob

info "Tools installed successfully"

# Clone diary repository if DIARY_DISK is set
if [ -n "$DIARY_DISK" ]; then
    step "Setting up diary..."
    
    # Setup diary URL
    if [ -n "$GITHUB_TOKEN" ]; then
        DIARY_URL="https://${GITHUB_TOKEN}@$(echo "$DIARY_DISK" | sed 's|https://||')"
    else
        DIARY_URL="$DIARY_DISK"
    fi
    
    if [ -d "$DEST_DIR/.diary" ]; then
        warn "Diary already exists, skipping clone"
    else
        if ! git clone "$DIARY_URL" "$DEST_DIR/.diary" >/dev/null 2>&1; then
            error "Failed to clone diary repository"
        else
            info "Diary repository cloned"
        fi
    fi
    
    # Copy diary commands to .claude/commands/
    mkdir -p "$DEST_DIR/.claude/commands"
    if cp "$DEST_DIR/.diary/.claude/commands/diary.sh" "$DEST_DIR/.claude/commands/" && \
       cp "$DEST_DIR/.diary/.claude/commands/diary.md" "$DEST_DIR/.claude/commands/"; then
        info "Diary commands installed"
    else
        error "Failed to copy diary commands"
    fi
else
    warn "DIARY_DISK not set, skipping diary setup"
fi

# Clone skills repository
step "Setting up skills from GitHub..."

# Setup skills repo URL
SKILLS_REPO="https://github.com/johnypaulintel/agentic.git"
if [ -n "$GITHUB_TOKEN" ]; then
    SKILLS_REPO="https://${GITHUB_TOKEN}@github.com/johnypaulintel/agentic.git"
fi

if ! git clone --depth 1 "$SKILLS_REPO" "$TEMP_DIR/skills-repo" >/dev/null 2>&1; then
    error "Failed to clone skills repository"
else
    # Create .claude/skills directory if it doesn't exist
    mkdir -p "$DEST_DIR/.claude/skills"
    
    # Copy all skills from the repo
    if [ -d "$TEMP_DIR/skills-repo/skills" ]; then
        SKILL_COUNT=0
        for skill_dir in "$TEMP_DIR/skills-repo/skills"/*; do
            if [ -d "$skill_dir" ]; then
                skill_name=$(basename "$skill_dir")
                if cp -r "$skill_dir" "$DEST_DIR/.claude/skills/"; then
                    info "  Installed skill: $skill_name"
                    SKILL_COUNT=$((SKILL_COUNT + 1))
                else
                    error "  Failed to copy skill: $skill_name"
                fi
            fi
        done
        
        if [ $SKILL_COUNT -gt 0 ]; then
            info "Total skills installed: $SKILL_COUNT"
        else
            warn "No skills found in repository"
        fi
    else
        warn "No skills directory found in repository"
    fi
fi

# Summary
echo ""
if [ $ERRORS -eq 0 ]; then
    info "Workspace initialized successfully!"
else
    error "Workspace initialized with $ERRORS error(s)"
    exit 1
fi

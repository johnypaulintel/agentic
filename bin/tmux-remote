#!/bin/bash

# Colors for better output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Check for arguments
FORCE_NEW=false
LIST_MODE=false

if [[ "$1" == "new" ]]; then
    FORCE_NEW=true
elif [[ "$1" == "list" ]]; then
    LIST_MODE=true
fi

# Configuration: Add your servers here
declare -A SERVERS
SERVERS["b60"]="172.26.38.184"
SERVERS["b70"]="172.26.36.152"
# Add more servers as needed: SERVERS["server_name"]="ip_address"

# Helper functions
print_header() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗ ERROR:${NC} $1" >&2
}

print_warning() {
    echo -e "${YELLOW}⚠ WARNING:${NC} $1"
}

print_info() {
    echo -e "${CYAN}ℹ${NC} $1"
}

# 1. Get current path and extract the server name
CURRENT_DIR=$(realpath "$PWD")
HOME_PREFIX="$HOME/remote/"

if [[ "$CURRENT_DIR" != "$HOME_PREFIX"* ]]; then
    # If list mode, we can proceed without being in a specific directory
    if [[ "$LIST_MODE" != true ]]; then
        print_header "tmux-remote"
        print_error "You are not inside a path under $HOME_PREFIX"
        echo ""
        print_info "Current directory: $CURRENT_DIR"
        print_info "Expected prefix:   $HOME_PREFIX"
        exit 1
    fi
fi

# Extract the server name (e.g., ~/remote/b60/... -> b60)
RELATIVE_PATH="${CURRENT_DIR#$HOME_PREFIX}"
SERVER_NAME=$(echo "$RELATIVE_PATH" | cut -d'/' -f1)

# Look up the IP
REMOTE_IP="${SERVERS[$SERVER_NAME]}"

# If list mode and not in a specific server directory, show server selection
if [[ "$LIST_MODE" == true && -z "$REMOTE_IP" ]]; then
    print_header "tmux-remote list"
    echo ""
    print_info "Select a server:"
    echo ""
    
    # Create array of server names
    SERVER_NAMES=()
    i=1
    for name in "${!SERVERS[@]}"; do
        SERVER_NAMES+=($name)
        echo -e "  ${CYAN}${i})${NC} $name → ${SERVERS[$name]}"
        ((i++))
    done
    
    echo ""
    read -p "Enter server number: " server_choice
    
    # Validate input
    if ! [[ "$server_choice" =~ ^[0-9]+$ ]] || [[ "$server_choice" -lt 1 ]] || [[ "$server_choice" -gt ${#SERVER_NAMES[@]} ]]; then
        print_error "Invalid selection"
        exit 1
    fi
    
    SERVER_NAME="${SERVER_NAMES[$((server_choice-1))]}"
    REMOTE_IP="${SERVERS[$SERVER_NAME]}"
    
    # We don't know the remote path, so we'll set it to home
    REMOTE_PATH=""
fi

if [[ -z "$REMOTE_IP" ]]; then
    print_header "tmux-remote"
    print_error "No IP mapping found for server '$SERVER_NAME'"
    echo ""
    print_info "Configured servers:"
    for name in "${!SERVERS[@]}"; do
        echo -e "  ${CYAN}•${NC} $name → ${SERVERS[$name]}"
    done
    exit 1
fi

# 2. Extract the remote path (everything after ~/remote/b60/)
# and use it as session name (replace / with _ to make it valid tmux session name)
REMOTE_PATH="${CURRENT_DIR#$HOME_PREFIX$SERVER_NAME}"
SESSION_NAME=$(echo "$REMOTE_PATH" | sed 's|^/||; s|/$||; s|/|_|g')
SESSION_NAME=$(echo "$SESSION_NAME" | tr ':' '-')

# Display connection info
print_header "tmux-remote"
print_info "Server:     ${BOLD}$SERVER_NAME${NC} (${REMOTE_IP})"
print_info "Session:    ${BOLD}$SESSION_NAME${NC}"
print_info "Remote dir: ${BOLD}$REMOTE_PATH${NC}"
echo ""

# Test SSH connection first
echo -e "${CYAN}→${NC} Testing SSH connection..."
if ! ssh -q -o BatchMode=yes -o ConnectTimeout=5 "johnypau@$REMOTE_IP" exit 2>/dev/null; then
    print_error "Cannot connect to $SERVER_NAME ($REMOTE_IP)"
    echo ""
    print_warning "Please check:"
    echo "  • SSH key is set up and loaded (ssh-add -l)"
    echo "  • Server is online and accessible"
    echo "  • Network connectivity to $REMOTE_IP"
    exit 1
fi
print_success "SSH connection established"

# If list mode, show all sessions and let user pick
if [[ "$LIST_MODE" == true ]]; then
    print_header "tmux-remote list - $SERVER_NAME"
    echo ""
    
    # Get list of all tmux sessions
    SESSION_LIST=$(ssh -q "johnypau@$REMOTE_IP" "tmux list-sessions -F '#S'" 2>/dev/null)
    
    if [[ -z "$SESSION_LIST" ]]; then
        print_warning "No active tmux sessions on $SERVER_NAME"
        exit 0
    fi
    
    # Display sessions with numbers
    print_info "Available sessions:"
    echo ""
    
    SESSION_ARRAY=()
    i=1
    while IFS= read -r session; do
        SESSION_ARRAY+=($session)
        echo -e "  ${CYAN}${i})${NC} $session"
        ((i++))
    done <<< "$SESSION_LIST"
    
    echo ""
    read -p "Enter session number to connect (or 'q' to quit): " session_choice
    
    # Check for quit
    if [[ "$session_choice" == "q" || "$session_choice" == "Q" ]]; then
        print_info "Cancelled"
        exit 0
    fi
    
    # Validate input
    if ! [[ "$session_choice" =~ ^[0-9]+$ ]] || [[ "$session_choice" -lt 1 ]] || [[ "$session_choice" -gt ${#SESSION_ARRAY[@]} ]]; then
        print_error "Invalid selection"
        exit 1
    fi
    
    SESSION_NAME="${SESSION_ARRAY[$((session_choice-1))]}"
    REMOTE_PATH="~"  # Default to home when connecting via list
    
    echo ""
    print_success "Selected session: ${BOLD}$SESSION_NAME${NC}"
    echo ""
fi

# Check if session exists
echo -e "${CYAN}→${NC} Checking tmux session..."
if ssh -q "johnypau@$REMOTE_IP" "tmux has-session -t ${SESSION_NAME}" 2>/dev/null; then
    SESSION_EXISTS=true
    if [[ "$FORCE_NEW" == true ]]; then
        print_warning "Killing existing session '${BOLD}${SESSION_NAME}${NC}'"
        if ssh -q "johnypau@$REMOTE_IP" "tmux kill-session -t ${SESSION_NAME}" 2>/dev/null; then
            print_success "Session killed successfully"
            SESSION_EXISTS=false
        else
            print_error "Failed to kill session"
            exit 1
        fi
    else
        print_success "Found existing session '${BOLD}${SESSION_NAME}${NC}'"
        echo ""
        echo -e "${GREEN}🔗 Attaching to existing session${NC}"
    fi
else
    SESSION_EXISTS=false
    print_info "Creating new session '${BOLD}${SESSION_NAME}${NC}'"
    echo ""
    echo -e "${GREEN}🆕 Creating new session${NC}"
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Connect - attach to existing session or create new one with bash, cd to the right directory, and reset
# If FORCE_NEW is set, session was already killed, so always create new
if [[ "$FORCE_NEW" == true && "$SESSION_EXISTS" == false ]]; then
    echo -e "${CYAN}→${NC} Creating fresh session after kill..."
fi
ssh -t "johnypau@$REMOTE_IP" "if tmux has-session -t ${SESSION_NAME} 2>/dev/null; then tmux attach -t ${SESSION_NAME}; else tmux new -s ${SESSION_NAME} 'cd $REMOTE_PATH && reset && exec /bin/bash'; fi"

# Capture exit status
SSH_EXIT_CODE=$?

# Handle disconnect
if [[ $SSH_EXIT_CODE -ne 0 ]]; then
    echo ""
    print_warning "Connection closed with exit code $SSH_EXIT_CODE"
fi
